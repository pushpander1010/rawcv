# PostgreSQL (Neon, Supabase, Railway, etc.)
# Prisma CLI reads this from `.env`; Next.js also loads `.env.local` — copy the same URL to both locally.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require
DIRECT_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require

# OpenAI
OPENAI_API_KEY=your_openai_api_key

# Google Gemini
GEMINI_API_KEY=your_gemini_api_key

# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key

# Groq (fast, cheap Llama — https://console.groq.com )
GROQ_API_KEY=your_groq_api_key

# OpenRouter (Qwen and many models — https://openrouter.ai )
OPENROUTER_API_KEY=your_openrouter_api_key
# Optional: site URL for OpenRouter rankings (use your production URL in prod)
OPENROUTER_SITE_URL=http://localhost:3000

# Razorpay
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# Resend (email verification — https://resend.com)
RESEND_API_KEY=re_your_resend_api_key
# The "from" address — must be a verified domain in Resend
EMAIL_FROM=rawcv <noreply@rawcv.app>

# NextAuth
NEXTAUTH_SECRET=your_nextauth_secret
NEXTAUTH_URL=http://localhost:3000

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Together AI
TOGETHER_API_KEY=tgp_v1_T2JD215KW6soGJY_37S7iv4pzsCHeNWzwWQe965BXvg

# ─── Dev-only admin login (local only, ignored in production) ─────────────────
# Set NODE_ENV=development to enable. Never set these in production.
DEV_ADMIN_EMAIL=admin@gmail.com
DEV_ADMIN_PASSWORD=admin
